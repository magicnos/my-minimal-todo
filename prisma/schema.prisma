// データベースの設計図（スキーマ）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model TodoTask {
  id                      Int      @id @default(autoincrement())
  taskTitle               String
  taskMemo                String?
  
  // 一回きりのタスク用
  taskDeadline            DateTime?
  
  taskPriority            String   @default("MEDIUM")
  taskType                String   // DAILY, SINGLE_DAY, MULTI_DAY, SINGLE
  
  // 毎日 (DAILY) 用：曜日ごとの回数
  habitDailySchedule      Json?    

  // 複数日 (MULTI_DAY) 用
  habitStartDay           Int?     // 0(日)-6(土)
  habitStartTime          String?  // "HH:mm"
  habitEndDay             Int?     // 0(日)-6(土)
  habitEndTime            String?  // "HH:mm"
  
  // 一日 (SINGLE_DAY) と 複数日 (MULTI_DAY) 用の目標回数
  habitTargetCount        Int?     @default(1)

  // 進行状況
  completedCount          Int      @default(0)
  lastCompletedAt         DateTime?

  // 並び順
  sortOrder               Int      @default(0)

  // 報酬設定
  rewardXP                Int      @default(10)
  rewardTiming            String   @default("EACH") // EACH (一回ごと), TOTAL (全達成時)

  // 通知設定（復活）
  notifications           TaskNotification[]

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ユーザーのステータス
model UserProfile {
  id            Int      @id @default(1)
  xp            Int      @default(0)
  level         Int      @default(1)
  xpScaling     Int      @default(100) // レベルアップに必要なXPの倍率
  updatedAt     DateTime @updatedAt
}

// 通知時間のリスト（復活）
model TaskNotification {
  id                Int      @id @default(autoincrement())
  notificationTime  DateTime
  todoTask          TodoTask @relation(fields: [todoTaskId], references: [id], onDelete: Cascade)
  todoTaskId        Int
}
