// データベースの設計図（スキーマ）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model TodoTask {
  id                      Int      @id @default(autoincrement())
  taskTitle               String
  taskMemo                String?
  
  taskStartTime           DateTime @default(now())
  taskDeadline            DateTime
  
  taskPriority            String   @default("MEDIUM")
  taskType                String   @default("SINGLE") // SINGLE or HABIT
  
  // --- 習慣設定の拡張 ---
  habitFrequency          String?  @default("DAILY") // DAILY, WEEKLY, MONTHLY
  habitDays               String?  // "0,1,2,3,4,5,6" (0=日曜日) 曜日指定用
  habitTargetCount        Int?     @default(1)       // 期間内に何回行うか
  
  lastCompletedAt         DateTime?

  notifications           TaskNotification[]
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model TaskNotification {
  id                Int      @id @default(autoincrement())
  notificationTime  DateTime
  todoTask          TodoTask @relation(fields: [todoTaskId], references: [id], onDelete: Cascade)
  todoTaskId        Int
}
