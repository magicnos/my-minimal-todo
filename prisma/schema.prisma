// データベースの設計図（スキーマ）です。
// 最新のPrisma（v7以降）では、接続先はここではなく別のファイルに書きます。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url は削除またはコメントアウトします
}

/**
 * TODOタスクの情報を保存する「本棚（モデル）」の定義です。
 */
model TodoTask {
  id                      Int      @id @default(autoincrement())
  taskTitle               String
  taskMemo                String?
  taskDeadline            DateTime
  taskPriority            String   @default("MEDIUM")
  taskType                String   @default("SINGLE")
  isNotificationEnabled   Boolean  @default(false)
  notificationLeadTimeMinutes Int  @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
