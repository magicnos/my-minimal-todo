// データベースの設計図（スキーマ）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model TodoTask {
  id                      Int      @id @default(autoincrement())
  taskTitle               String
  taskMemo                String?
  
  taskStartTime           DateTime @default(now())
  taskDeadline            DateTime
  
  taskPriority            String   @default("MEDIUM")
  taskType                String   @default("SINGLE") // SINGLE or HABIT
  
  // 習慣の頻度（DAILY: 毎日, WEEKLY: 毎週, MONTHLY: 毎月）
  habitFrequency          String?  @default("DAILY")
  
  // 最後に完了ボタンを押した日時（習慣用）
  lastCompletedAt         DateTime?

  notifications           TaskNotification[]
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model TaskNotification {
  id                Int      @id @default(autoincrement())
  notificationTime  DateTime
  todoTask          TodoTask @relation(fields: [todoTaskId], references: [id], onDelete: Cascade)
  todoTaskId        Int
}
