// データベースの設計図（スキーマ）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model TodoTask {
  id                      Int      @id @default(autoincrement())
  taskTitle               String
  taskMemo                String?
  
  // 開始時間（長期目標の場合は null になります）
  taskStartTime           DateTime?
  
  // 期限（締め切り）
  taskDeadline            DateTime
  
  taskPriority            String   @default("MEDIUM")
  
  // タスクのタイプ（DAILY, WEEKLY, MONTHLY, LONG_TERM）
  taskType                String   
  
  // 習慣設定：期間（日単位。毎週/毎月で使用）
  habitPeriodDays         Int?     
  
  // 習慣設定：期間内の目標回数（毎週/毎月で使用）
  habitTargetCount        Int?     @default(1)
  
  // 習慣設定：曜日ごとの回数（DAILYで使用。JSON形式で {"0":1, "1":2...} のように保存）
  habitDailySchedule      Json?    

  // 実行状態の管理
  completedCount          Int      @default(0) // 現在の期間内で何回完了したか
  lastCompletedAt         DateTime?            // 最後に完了ボタンを押した日時

  notifications           TaskNotification[]
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model TaskNotification {
  id                Int      @id @default(autoincrement())
  notificationTime  DateTime
  todoTask          TodoTask @relation(fields: [todoTaskId], references: [id], onDelete: Cascade)
  todoTaskId        Int
}
