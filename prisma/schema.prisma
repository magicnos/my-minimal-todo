// データベースの設計図（スキーマ）です。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

// TODOタスクの本体
model TodoTask {
  id                      Int      @id @default(autoincrement())
  taskTitle               String
  taskMemo                String?
  
  // 開始時間（新しく追加）
  taskStartTime           DateTime @default(now())
  
  // 期限
  taskDeadline            DateTime
  
  taskPriority            String   @default("MEDIUM")
  taskType                String   @default("SINGLE")
  
  // 通知設定（1つのタスクに対して複数を設定可能に）
  notifications           TaskNotification[]
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// 通知時間のリスト
model TaskNotification {
  id                Int      @id @default(autoincrement())
  
  // 具体的な通知日時
  notificationTime  DateTime
  
  // どのタスクに紐付いているか
  todoTask          TodoTask @relation(fields: [todoTaskId], references: [id], onDelete: Cascade)
  todoTaskId        Int
}
